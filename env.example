# ─── Telegram ───────────────────────────────────────────
# BotFather'dan aldığın token
PIZZA_BOT_TOKEN=your_telegram_bot_token_here

# Sadece bu kullanıcılar bota erişebilir (virgülle ayır)
# Telegram user ID'ni bulmak için @userinfobot'a mesaj at
AUTHORIZED_USER_IDS=123456789

# Otomatik raporların gönderileceği chat ID (genellikle kendi ID'n)
ADMIN_CHAT_ID=123456789

# ─── Veritabanı ──────────────────────────────────────────
# Railway PostgreSQL veya Supabase connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── AI ─────────────────────────────────────────────────
# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
